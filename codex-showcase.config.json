{
  "artifactSchema": "codex-showcase-project",
  "defaultOutputDir": "codex-showcase-export",
  "defaultCardAnimation": "liquid",
  "cardAnimations": ["liquid", "flow", "terrain", "orbit", "rain"],
  "redactionPatterns": [
    {
      "name": "email",
      "pattern": "\\b[A-Z0-9._%+-]+@[A-Z0-9.-]+\\.[A-Z]{2,}\\b",
      "flags": "gi",
      "replacement": "[redacted-email]"
    },
    {
      "name": "api-key-like-token",
      "pattern": "\\b(?:sk|pk|rk|ghp|github_pat|xox[baprs]|vercel|supabase|railway|openrouter|anthropic|openai)[A-Za-z0-9_\\-]{16,}\\b",
      "flags": "gi",
      "replacement": "[redacted-token]"
    },
    {
      "name": "jwt",
      "pattern": "\\beyJ[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\.[A-Za-z0-9_-]+\\b",
      "flags": "g",
      "replacement": "[redacted-jwt]"
    },
    {
      "name": "aws-access-key",
      "pattern": "\\b(?:AKIA|ASIA)[A-Z0-9]{16}\\b",
      "flags": "g",
      "replacement": "[redacted-aws-key]"
    },
    {
      "name": "private-key-block",
      "pattern": "-----BEGIN(?: [A-Z0-9]+)? PRIVATE KEY-----[\\s\\S]*?-----END(?: [A-Z0-9]+)? PRIVATE KEY-----",
      "flags": "g",
      "replacement": "[redacted-private-key]"
    },
    {
      "name": "basic-auth-url",
      "pattern": "https?:\\/\\/[^\\s/:]+:[^\\s/@]+@",
      "flags": "gi",
      "replacement": "https://[redacted-credentials]@"
    },
    {
      "name": "private-env-assignment",
      "pattern": "\\b[A-Z][A-Z0-9_]*(?:SECRET|TOKEN|API_KEY|PASSWORD|PRIVATE_KEY)\\s*=\\s*[^\\s]+",
      "flags": "g",
      "replacement": "[redacted-secret-assignment]"
    },
    {
      "name": "local-home-path",
      "pattern": "/Users/[^\\s/]+",
      "flags": "g",
      "replacement": "/Users/[redacted-user]"
    },
    {
      "name": "shell-prompt-identity",
      "pattern": "\\b[a-z][A-Za-z0-9._-]{0,63}@[A-Z][A-Za-z0-9.-]{2,127}",
      "flags": "g",
      "replacement": "[redacted-shell-user]"
    },
    {
      "name": "memory-citation-block",
      "pattern": "<oai-mem-citation>[\\s\\S]*?<\\/oai-mem-citation>",
      "flags": "g",
      "replacement": ""
    }
  ]
}
